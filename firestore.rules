rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============ Helper Functions ============

    // 로그인 여부 확인
    function isAuthenticated() {
      return request.auth != null;
    }

    // 본인 확인
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 사용자 문서 기반 그룹 목록
    function userGroupIds() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data != null && userDoc.data.groupIds != null
        ? userDoc.data.groupIds
        : [];
    }

    // 그룹 멤버 여부 확인 (memberIds / user.groupIds / 결정적 membership ID 순서로 확인)
    function isMemberOfGroup(groupId) {
      let familyDoc = get(/databases/$(database)/documents/families/$(groupId));
      let familyMemberIds = familyDoc.data != null && familyDoc.data.memberIds != null
        ? familyDoc.data.memberIds
        : [];

      return isAuthenticated() && (
        familyMemberIds.hasAny([request.auth.uid]) ||
        userGroupIds().hasAny([groupId]) ||
        exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + groupId))
      );
    }

    // 그룹 관리자 확인 (결정적 membership ID 기준)
    function isGroupAdmin(groupId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + groupId)) &&
        get(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + groupId)).data.role == 'admin';
    }

    // sharedGroups 접근 가능 여부 (user.groupIds 기반)
    function hasSharedGroupAccess(sharedGroups) {
      return sharedGroups != null && userGroupIds().hasAny(sharedGroups);
    }

    // ============ Users Collection ============
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      // 사용자 하위 컬렉션: todos (공유 todo 토글 허용)
      match /todos/{todoId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
        // 공유 todo 토글: 그룹 멤버가 isCompleted/completedAt만 수정 가능
        allow update: if isAuthenticated()
          && resource.data.visibility == 'shared'
          && hasSharedGroupAccess(resource.data.sharedGroups)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isCompleted', 'completedAt']);
      }

      // 사용자 하위 컬렉션 (business_reviews, albums 등 - todos 제외)
      match /{subcollection}/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // ============ CollectionGroup: Albums ============
    // 공유된 앨범은 sharedGroups에 포함된 그룹 멤버만 읽기 가능
    match /{path=**}/albums/{albumId} {
      allow read: if isAuthenticated() && (
        // 본인 앨범이거나
        resource.data.createdBy == request.auth.uid ||
        // 공유 앨범 + 공유 그룹 접근 권한이 있는 경우
        (
          resource.data.visibility == 'shared' &&
          (
            hasSharedGroupAccess(resource.data.sharedGroups) ||
            (resource.data.familyId != null && isMemberOfGroup(resource.data.familyId))
          )
        )
      );
      // 쓰기는 users/{userId}/albums 경로에서만 허용 (위의 규칙 적용)
    }

    // ============ CollectionGroup: Todos (Phase 2 멀티그룹 공유) ============
    // 공유된 할일/일정은 소유자이거나 sharedGroups에 포함된 그룹 멤버만 읽기 가능
    match /{path=**}/todos/{todoId} {
      allow read: if isAuthenticated() && (
        // 본인 소유이거나
        resource.data.ownerId == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        // 공유 항목 + 공유 그룹 접근 권한이 있는 경우
        (
          resource.data.visibility == 'shared' &&
          hasSharedGroupAccess(resource.data.sharedGroups)
        )
      );
      // 쓰기는 families/{groupId}/todos 경로에서만 허용 (위의 규칙 적용)
    }

    // ============ Families (Groups) Collection ============
    match /families/{familyId} {
      // 읽기: 인증된 사용자 (초대 코드로 가입 시 멤버 아닌 상태에서 조회 필요)
      allow read: if isAuthenticated();

      // 생성: 본인이 memberIds에 포함된 경우만
      allow create: if isAuthenticated()
        && request.resource.data.memberIds != null
        && request.resource.data.memberIds.hasAny([request.auth.uid]);
      // 수정: 그룹 멤버 또는 가입 시 본인을 memberIds에 추가하는 경우
      allow update: if isAuthenticated() && (
        isMemberOfGroup(familyId) ||
        // 초대 코드로 가입 시: memberIds에 본인 추가만 허용
        request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.resource.data.memberIds.hasAny([request.auth.uid])
      );
      allow delete: if isGroupAdmin(familyId);

      // 앨범 댓글: 읽기는 그룹 멤버, 생성은 그룹 멤버, 수정/삭제는 작성자만
      match /album_comments/{commentId} {
        allow read: if isMemberOfGroup(familyId);
        allow create: if isMemberOfGroup(familyId)
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isMemberOfGroup(familyId)
          && resource.data.userId == request.auth.uid;
      }

      // 가족 하위 컬렉션 (todos, events, memories, transactions)
      match /{subcollection}/{docId} {
        allow read, write: if isMemberOfGroup(familyId);
      }
    }

    // ============ Memberships Collection ============
    match /memberships/{membershipId} {
      // 읽기: 본인 또는 같은 그룹 멤버
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isMemberOfGroup(resource.data.groupId)
      );

      // 생성: 본인 membership만 생성 가능 + 결정적 문서 ID 강제
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.groupId is string
        && membershipId == request.auth.uid + '_' + request.resource.data.groupId
        && exists(/databases/$(database)/documents/families/$(request.resource.data.groupId));

      // 수정:
      // - 본인 프로필 수정 허용(userId/groupId 불변)
      // - 그룹 관리자는 role/groupName만 타 멤버 대상으로 수정 가능
      allow update: if isAuthenticated() && (
        (
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.groupId == resource.data.groupId
        ) || (
          isGroupAdmin(resource.data.groupId) &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.groupId == resource.data.groupId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'groupName'])
        )
      );

      // 삭제: 본인 멤버십만 삭제 가능 (그룹 탈퇴)
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ============ Communities Collection ============
    match /communities/{communityId} {
      // 커뮤니티는 완전 공개 읽기
      allow read: if true;

      // 생성은 본인 계정으로만 허용
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 50
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 300;

      // 커뮤니티 수정: 개설자 전체 수정 또는 인증된 사용자의 updatedAt만 수정
      allow update: if isAuthenticated() && (
        (
          resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == resource.data.createdBy
        ) || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt'])
        )
      );
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;

      // 게시글
      match /posts/{postId} {
        allow read: if true;

        allow create: if isAuthenticated()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.communityId == communityId
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 120
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 5000;

        allow update: if isAuthenticated()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.communityId == resource.data.communityId;

        allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;

        // 댓글
        match /comments/{commentId} {
          allow read: if true;

          allow create: if isAuthenticated()
            && request.resource.data.authorId == request.auth.uid
            && request.resource.data.communityId == communityId
            && request.resource.data.postId == postId
            && request.resource.data.content is string
            && request.resource.data.content.size() > 0
            && request.resource.data.content.size() <= 2000;

          allow update: if isAuthenticated()
            && resource.data.authorId == request.auth.uid
            && request.resource.data.authorId == resource.data.authorId
            && request.resource.data.communityId == resource.data.communityId
            && request.resource.data.postId == resource.data.postId;

          allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
        }
      }
    }

    // ============ Analysis Jobs Collection ============
    match /analysis_jobs/{jobId} {
      // 본인 작업만 읽기 가능
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // 클라이언트에서 직접 생성/수정 불가 (Cloud Run에서만 처리)
      // 취소 요청 시에만 status 업데이트 허용
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.status == 'cancelled';

      // 직접 생성/삭제 불가 (서버 사이드에서만)
      allow create: if false;
      allow delete: if false;
    }

    // ============ AI Cache Collection ============
    match /ai_cache/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      match /{subcollection}/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }
  }
}
