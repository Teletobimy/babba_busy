rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============ Helper Functions ============

    // 로그인 여부 확인
    function isAuthenticated() {
      return request.auth != null;
    }

    // 본인 확인
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ============ Users Collection ============
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      // 사용자 하위 컬렉션 (business_reviews 등)
      match /{subcollection}/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // ============ Families (Groups) Collection ============
    match /families/{familyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();

      // 가족 하위 컬렉션 (todos, events, memories, transactions)
      match /{subcollection}/{docId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // ============ Memberships Collection ============
    match /memberships/{membershipId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ============ Analysis Jobs Collection ============
    match /analysis_jobs/{jobId} {
      // 본인 작업만 읽기 가능
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // 클라이언트에서 직접 생성/수정 불가 (Cloud Run에서만 처리)
      // 취소 요청 시에만 status 업데이트 허용
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.status == 'cancelled';

      // 직접 생성/삭제 불가 (서버 사이드에서만)
      allow create: if false;
      allow delete: if false;
    }

    // ============ AI Cache Collection ============
    match /ai_cache/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      match /{subcollection}/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }
  }
}
